# =============================================================================
# AptivEye Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# --- LLM Provider Keys ---
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OLLAMA_BASE_URL=http://localhost:11434

# --- Default Model ---
DEFAULT_MODEL_TIER=light
LIGHT_MODEL=gpt-4o-mini
STANDARD_MODEL=gpt-4o
HEAVY_MODEL=gpt-4o
# Alternative: use claude models
# LIGHT_MODEL=claude-haiku-4-5-20251001
# STANDARD_MODEL=claude-sonnet-4-6
# HEAVY_MODEL=claude-opus-4-8

# --- Local Model (for sensitive data) ---
LOCAL_MODEL_ENABLED=false
LOCAL_MODEL_NAME=llama3.1:8b

# --- Sandbox ---
SANDBOX_ENABLED=false
SANDBOX_IMAGE=aptiveye-sandbox:latest
SANDBOX_NETWORK_MODE=none
SANDBOX_TIMEOUT_SECONDS=300

# --- Memory ---
VECTOR_STORE_TYPE=chroma
VECTOR_STORE_PATH=./data/vector_store
CHROMA_PERSIST_DIR=./data/chroma

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=./data/logs/aptiveye.log

# --- Agent ---
AGENT_MAX_ITERATIONS=20
AGENT_TIMEOUT_SECONDS=600
AGENT_MAX_WORKERS=5

# --- Security ---
LOOP_DETECTION_THRESHOLD=3
HITL_ENABLED=true
AUDIT_LOG_PATH=./data/audit

# --- Report ---
REPORT_OUTPUT_DIR=./data/reports

# --- Asset Discovery API Keys & Endpoints ---
# All URLs are independently configurable — set to your own mirror/proxy/gateway.

# FOFA (https://fofa.info) — network space search engine
# NOTE: FOFA requires BOTH email and API key for authentication (base64-encoded Basic Auth)
FOFA_EMAIL=
FOFA_API_KEY=
# Optional: point to custom mirror/proxy (default: https://fofa.info/api/v1)
FOFA_API_URL=https://fofa.info/api/v1

# ZoomEye (https://zoomeye.org) — network space search engine
ZOOMEYE_API_KEY=
# Optional: point to custom mirror/proxy (default: https://api.zoomeye.org)
ZOOMEYE_API_URL=https://api.zoomeye.org

# ICP备案查询
ICP_API_KEY=
ICP_API_URL=https://api.beian.miit.gov.cn
ICP_PUBLIC_URL=https://api.devopsclub.cn/api/icpquery

# 企查查 — company registration & ownership
QICHACHA_API_KEY=
QICHACHA_API_URL=https://api.qichacha.com

# 天眼查 — company information search
TIANYANCHA_API_KEY=
TIANYANCHA_API_URL=https://api.tianyancha.com

# 零零信安 — security data platform
LINGLING_API_KEY=
LINGLING_API_URL=https://api.0zero.cn

# Hunter.io — email discovery
HUNTER_API_KEY=
HUNTER_API_URL=https://api.hunter.io/v2

# crt.sh — certificate transparency log (free, no auth)
CRTSH_API_URL=https://crt.sh

# 搜狗微信搜索
WEIXIN_SEARCH_URL=https://weixin.sogou.com/weixin

# 微信小程序搜索
MINIPROGRAM_SEARCH_URL=https://mp.weixin.qq.com/wxamp/search

# iTunes App Store
ITUNES_SEARCH_URL=https://itunes.apple.com/search
